---
const models = [
  {
    label: "Ongoing",
    title: "Role fill",
    description: "I embed in your team at a senior level, leading the product function or reinforcing the team you already have.",
  },
  {
    label: "Defined scope",
    title: "Project-based",
    description: "A defined engagement with a clear deliverable: a product strategy, a revamped experience, or an AI-powered prototype.",
  },
  {
    label: "Lightweight",
    title: "Advising",
    description: "Ongoing access to an experienced product brain: regular calls, async support, and a sounding board when you need one.",
  },
];
---

<section id="how-i-work" class="py-14 px-6 fade-in">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading font-medium text-[2rem] tracking-tight mb-3">
      How I work
    </h2>
    <p class="text-muted mb-8 max-w-2xl">
      Arrangements are flexible, every company is different.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {models.map(m => (
        <div class="border border-border rounded-lg p-6 flex flex-col">
          <span class="text-xs font-medium uppercase tracking-wider text-terracotta mb-3">
            {m.label}
          </span>
          <h3 class="font-heading font-medium text-lg text-ink mb-2">
            {m.title}
          </h3>
          <p class="text-sm text-muted leading-relaxed">
            {m.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
