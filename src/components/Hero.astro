---

---

<section class="relative overflow-hidden min-h-[85svh] lg:min-h-[70svh] flex items-start lg:items-center pt-24 pb-12 px-6">
  <div class="lg:hidden absolute inset-0 z-0 bg-no-repeat" style="background-image:url('/images/ted-portrait.webp'); background-size:cover; background-position:center 85%;">
    <div class="absolute inset-0 bg-gradient-to-b from-cream from-[28%] to-transparent to-[72%]"></div>
  </div>

  <div class="max-w-6xl mx-auto w-full relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-center gap-10 lg:gap-12">
      <div class="max-w-lg">
        <h1 class="font-heading font-bold text-[clamp(2.25rem,5vw,3.25rem)] leading-[1.08] tracking-tight text-ink">
          Fractional Product
          <span class="rotator block overflow-hidden">
            <span class="rotator__word inline-block text-terracotta">Leader</span>
          </span>
        </h1>
        <p class="mt-5 text-[clamp(1rem,2vw,1.125rem)] text-muted leading-relaxed">
          I work with startups and founders to ship products that survive contact with the messiness of the real world.
        </p>
        <div class="hidden lg:block mt-8">
          <a
            href="#contact"
            class="text-sm font-medium text-cream bg-terracotta hover:bg-terracotta-dark px-5 py-2.5 rounded-md transition-colors"
          >
            Get in touch
          </a>
        </div>
      </div>

      <div class="hidden lg:block shrink-0">
        <div class="rounded-xl overflow-hidden shadow-xl w-80">
          <img src="/images/ted-portrait.webp" alt="Ted Herringshaw" class="w-full h-auto" />
        </div>
      </div>
    </div>
  </div>

  <div class="lg:hidden absolute left-6 bottom-10 z-20">
    <a
      href="#contact"
      class="text-sm font-medium text-cream bg-terracotta hover:bg-terracotta-dark px-5 py-2.5 rounded-md transition-colors shadow-lg"
    >
      Get in touch
    </a>
  </div>
</section>

<style>
  .rotator {
    height: 1.15em;
  }
  .rotator__word {
    line-height: 1.15;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .rotator__word {
      transition: opacity 0.4s ease;
    }
  }
</style>

<script>
  const wordEl = document.querySelector<HTMLElement>(".rotator__word");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (wordEl) {
    const words = ["Leader", "Builder", "Operator", "Owner", "Strategist", "Generalist"];
    let i = 0;
    setInterval(() => {
      wordEl.style.opacity = "0";
      if (!reduce) wordEl.style.transform = "translateY(-115%)";
      setTimeout(() => {
        i = (i + 1) % words.length;
        wordEl.textContent = words[i];
        if (!reduce) {
          wordEl.style.transition = "none";
          wordEl.style.transform = "translateY(115%)";
          wordEl.getBoundingClientRect(); // force reflow
          wordEl.style.transition = "";
          wordEl.style.transform = "translateY(0)";
        }
        wordEl.style.opacity = "1";
      }, reduce ? 250 : 450);
    }, 2400);
  }
</script>
