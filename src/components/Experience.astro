---
import { experience } from '../data/experience';
---

<section id="background" class="py-20 px-6 fade-in">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-3 mb-4">
      <h2 class="font-heading font-medium text-[2rem] tracking-tight">
        My background
      </h2>
      <a href="https://www.linkedin.com/in/tedherringshaw/" target="_blank" rel="noopener" class="text-muted hover:text-terracotta hover:border-terracotta border border-border rounded-md p-1.5 transition-colors" aria-label="View LinkedIn profile">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z" />
          <rect x="2" y="9" width="4" height="12" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
    </div>
    <p class="text-muted mb-12 max-w-2xl">
      Product leader with 16 years of career experience across software and hardware businesses. Generalist who enjoys new problem spaces and building products that need to withstand the messiness of the real world.
    </p>

    <div class="relative space-y-0">
      <div class="absolute left-0 top-[10px] bottom-[10px] w-px bg-border"></div>
      {experience.map((role) => (
        <div class="relative pl-8 pb-12 last:pb-0 group">
          <div class={`absolute left-[-5px] top-[10px] w-2.5 h-2.5 rounded-full ${role.current ? 'bg-terracotta' : 'bg-border'} z-10`}></div>

          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-3 mb-1">
            {role.url ? (
              <h3 class="font-heading font-medium text-lg text-ink">
                <a href={role.url} target="_blank" rel="noopener" class="hover:text-terracotta transition-colors">{role.company}</a>
              </h3>
            ) : (
              <h3 class="font-heading font-medium text-lg text-ink">
                {role.company}
              </h3>
            )}
            <span class="text-sm text-muted">{role.dates}</span>
          </div>

          <p class="text-sm font-medium text-muted mb-3">{role.title}</p>

          <div class="flex flex-wrap gap-1.5">
            {role.industry.map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-terracotta-light text-terracotta-dark font-medium">
                {tag}
              </span>
            ))}
            {role.stage.map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-ink/[0.06] text-ink/70 font-medium">
                {tag}
              </span>
            ))}
            {role.tags.map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full border border-border text-muted">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
