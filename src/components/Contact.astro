---

---

<section id="contact" class="py-16 px-6 bg-ink fade-in">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="font-heading font-medium text-[2rem] tracking-tight mb-4 text-cream">
      Get in touch
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-lg mx-auto mt-10">
      <button
        id="copy-email"
        class="flex items-center gap-3 px-5 py-4 border border-cream/15 rounded-lg hover:border-terracotta hover:bg-terracotta/10 transition-all group cursor-pointer text-left"
      >
        <svg class="w-5 h-5 text-cream/40 group-hover:text-terracotta transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 4L12 13L2 4" />
        </svg>
        <div>
          <p class="text-sm font-medium text-cream" id="copy-email-label">Email</p>
          <p class="text-xs text-cream/50 flex items-center gap-1.5">
            tedherringshaw@gmail.com
            <svg id="copy-email-icon" class="w-3 h-3 text-cream/30 group-hover:text-terracotta transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
          </p>
        </div>
      </button>

      <button
        id="copy-phone"
        class="flex items-center gap-3 px-5 py-4 border border-cream/15 rounded-lg hover:border-terracotta hover:bg-terracotta/10 transition-all group cursor-pointer text-left"
      >
        <svg class="w-5 h-5 text-cream/40 group-hover:text-terracotta transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-cream" id="copy-phone-label">Call or text</p>
          <p class="text-xs text-cream/50 flex items-center gap-1.5">
            734.771.2595
            <svg id="copy-phone-icon" class="w-3 h-3 text-cream/30 group-hover:text-terracotta transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
          </p>
        </div>
      </button>

      <a
        href="https://www.linkedin.com/in/tedherringshaw/"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-3 px-5 py-4 border border-cream/15 rounded-lg hover:border-terracotta hover:bg-terracotta/10 transition-all group"
      >
        <svg class="w-5 h-5 text-cream/40 group-hover:text-terracotta transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z" />
          <rect x="2" y="9" width="4" height="12" />
          <circle cx="4" cy="4" r="2" />
        </svg>
        <div class="text-left">
          <p class="text-sm font-medium text-cream">Connect</p>
          <p class="text-xs text-cream/50">linkedin.com/in/tedherringshaw</p>
        </div>
      </a>

      <a
        href="https://calendar.app.google/mVhzMBYUsNCMYy3t5"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-3 px-5 py-4 border border-cream/15 rounded-lg hover:border-terracotta hover:bg-terracotta/10 transition-all group"
      >
        <svg class="w-5 h-5 text-cream/40 group-hover:text-terracotta transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <div class="text-left">
          <p class="text-sm font-medium text-cream">Book a call</p>
          <p class="text-xs text-cream/50">Google Calendar</p>
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  function setupCopy(btnId: string, labelId: string, text: string, originalLabel: string) {
    const btn = document.getElementById(btnId)!;
    const label = document.getElementById(labelId)!;
    btn.addEventListener("click", async () => {
      await navigator.clipboard.writeText(text);
      label.textContent = "Copied!";
      setTimeout(() => { label.textContent = originalLabel; }, 2000);
    });
  }
  setupCopy("copy-email", "copy-email-label", "tedherringshaw@gmail.com", "Email");
  setupCopy("copy-phone", "copy-phone-label", "734-771-2595", "Call or text");
</script>
