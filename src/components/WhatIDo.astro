---
import { strengths } from '../data/strengths';
---

<section id="what-i-do" class="py-20 px-6 bg-surface fade-in">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading font-medium text-[2rem] tracking-tight mb-12">
      What I do
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {strengths.map(s => (
        <div class="bg-cream border border-border rounded-lg p-6">
          <h3 class="font-heading font-medium text-[15px] text-ink mb-2">
            {s.title}
          </h3>
          <p class="text-sm text-muted leading-relaxed">
            {s.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
